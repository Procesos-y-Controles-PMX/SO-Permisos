# Conexión principal a Supabase
NEXT_PUBLIC_SUPABASE_URL=URL_DE_SUPABASE
NEXT_PUBLIC_SUPABASE_ANON_KEY=CLAVE_DE_SUPABASE

# Configuración de Storage (Buckets)
NEXT_PUBLIC_SUPABASE_BUCKET=NOMBRE_DEL_BUCKET

# Conexión al Backend (FastAPI)
NEXT_PUBLIC_API_URL=URL_DEL_BACKEND

# Portal SSO (optional — when set, /login redirects to the unified portal)
PORTAL_HANDOFF_SECRET=shared-secret-with-portal
NEXT_PUBLIC_PORTAL_URL=http://localhost:3005